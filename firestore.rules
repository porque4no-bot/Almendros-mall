rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: get the role for the current authenticated user
    function userRole() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return request.auth != null && userRole() == 'admin';
    }

    function isEditor() {
      return request.auth != null && userRole() == 'editor';
    }

    function canWrite() {
      return isAdmin() || isEditor();
    }

    // --- usuarios collection ---
    match /usuarios/{uid} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // --- proyecto (main document) ---
    match /proyecto/{docId} {
      allow read: if request.auth != null;
      allow write: if canWrite();
    }

    // --- proyectos (optimized daily logs sub-collection) ---
    match /proyectos/{projectId}/{document=**} {
      allow read: if request.auth != null;
      allow write: if canWrite();
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
